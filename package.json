{
  "name": "shill-it-launchpad",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @shill-it/web dev",
    "build": "pnpm --filter @shill-it/web build",
    "build:anchor": "pnpm --filter @shill-it/anchor build",
    "test:anchor": "pnpm --filter @shill-it/anchor test",
    "bagworker:detect": "ts-node --project scripts/tsconfig.json scripts/add-tracked-token-and-run-detect.ts",
    "seed:token": "node scripts/seed-tracked-token.js",
    "create-dbc-config": "node scripts/create-dbc-config.mjs"
