    "@solana/web3.js": "^1.95.0",
    "@supabase/supabase-js": "^2.45.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.6.1",
    "ts-node": "^10.9.2"
  },
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
