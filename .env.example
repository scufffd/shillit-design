# ============ Shill It Launchpad – copy to .env and fill ============

# --- Solana (mainnet) ---
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Wallet + launch: use same Helius mainnet RPC
NEXT_PUBLIC_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Meteora DBC config key (create at launch.meteora.ag on mainnet). Also set NEXT_PUBLIC_ for the launch page.
POOL_CONFIG_KEY=your_meteora_dbc_config_pubkey
NEXT_PUBLIC_POOL_CONFIG_KEY=your_meteora_dbc_config_pubkey
ANCHOR_PROVIDER_CLUSTER=mainnet

# --- Cloudflare R2 (images) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=shillit-images

# --- Database: SQLite (default) or Supabase (when live) ---
# Leave NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY empty to use local SQLite (.data/shillit.db).
# Set both to switch to Supabase; no code change needed.
DATABASE_PATH=
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Pinata (IPFS token metadata; optional – fallback is in-memory metadata URL) ---
# Use JWT (recommended) or API key + secret. When set, launch uploads image + Metaplex metadata to Pinata.
# PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# PINATA_API_KEY=
# PINATA_SECRET_API_KEY=

# --- Arweave (permanent image storage via Bundlr) ---
BUNDLR_PRIVATE_KEY=
ARWEAVE_NODE=https://arweave.net

# --- Treasury & CTO ---
TREASURY_VAULT_PDA=your_treasury_vault_pubkey
SQUADS_MULTISIG_PUBKEY=
# Dedicated CTO fee wallet (SOL). Fee is paid here; admin confirms on /admin/cto.
CTO_TREASURY_WALLET=
CTO_FEE_LAMPORTS=50000000000
INACTIVITY_DAYS=60
MAX_MC_USD_CTO=30000

# --- Bagworker rewards (X verification + engagement weighting) ---
# From X Developer Portal: use OAuth 2.0 Client ID + Client Secret for Sign in with X.
# (API Key / API Key Secret = consumer keys; Access Token / Secret = user context – not needed in .env for PKCE.)
X_CLIENT_ID=your_oauth2_client_id
X_CLIENT_SECRET=your_oauth2_client_secret
X_CALLBACK_URL=http://localhost:3000/api/bagworker/callback/x
X_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAIeqzwEAAAAANUlJYOhWe6AR3Tytl3JhBAtzYlA%3DlCMtqoaPtasXMMImWZ9DMeZMxa7WbwLPmRgBMtMEM70bVorrmH
# X_BEARER_TOKEN = app-only Bearer for search + public metrics. Generate in X portal under Keys and tokens.
BAGWORKER_W_IMPRESSIONS=1
BAGWORKER_W_LIKES=2
BAGWORKER_W_RETWEETS=3
BAGWORKER_W_REPLIES=2
BAGWORKER_PERIOD_DAYS=7
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Deployer profile (required to launch; daily cap; fee scaling by rating) ---
# SOL wallet that receives the deployer profile upfront fee.
DEPLOYER_PROFILE_TREASURY_WALLET=
NEXT_PUBLIC_DEPLOYER_PROFILE_TREASURY_WALLET=
# Profile fee in lamports (e.g. 100000000 = 0.1 SOL). Server verifies payment.
DEPLOYER_PROFILE_FEE_LAMPORTS=100000000
# Shown on deployer page for building the payment tx.
NEXT_PUBLIC_DEPLOYER_PROFILE_FEE_SOL=0.1
# Max deploys per wallet per day (UTC).
DEPLOYER_DAILY_CAP=3

# --- Fees & rewards (claim partner, distribute to holders, buyback/burn) ---
# Launchpad wallet that claims partner fees and runs distribution; base58 or JSON array.
LAUNCHPAD_PRIVATE_KEY=
# Optional: protect POST /api/rewards/run (cron)
# REWARDS_CRON_TOKEN=your-secret-token
# Optional: platform cut before split (e.g. 0.05 = 5%)
# PLATFORM_FEE_PCT=0.05
# PLATFORM_WALLET=your_platform_sol_wallet
# Min token balance (raw) to qualify for holder rewards
# MIN_HOLDER_BALANCE=1

# --- Fee distributor (Merkle claim; avoids deployer wallet airdrop clustering) ---
# Program that holds a vault PDA per mint and lets holders claim using Merkle proofs.
# Terminals can integrate via /api/distributor/* endpoints.
DISTRIBUTOR_PROGRAM_ID=
# When set to true/1, holder share is published as a Merkle epoch and funded on-chain; holders claim via API/terminals.
USE_DISTRIBUTOR_FOR_HOLDERS=
# When set to true/1, the server will auto-run init_mint for a new token after launch (called from /api/image/register).
AUTO_INIT_DISTRIBUTOR_ON_REGISTER=
# Where epoch JSON files live (server-only). Default: .data/fee_distributions
FEE_DISTRIBUTIONS_DIR=

# --- Security / API ---
API_RATE_LIMIT_PER_MIN=30
HELIUS_WEBHOOK_SECRET=
# Comma-separated SOL wallet addresses allowed to use admin endpoints (e.g. return-funds, /admin/cto).
# SHILLIT_ADMIN_WALLETS=addr1,addr2

# --- Optional: Meteora Invent (if merging with fun-launch) ---
# R2_* and RPC_URL and POOL_CONFIG_KEY shared with fun-launch .env
